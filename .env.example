# Notes:
# - Copy this file to .env and update values before running the reset script.
# - The DB user must have privileges to DROP/CREATE databases (or run the script
#   using a PostgreSQL superuser like 'postgres').
# - To run the reset: `npm run db:reset`# بيانات الاتصال بقاعدة البيانات المحلية PostgreSQL
# WARNING: لا تستخدم بادئة VITE_ لمتغيرات قاعدة البيانات — Vite يكشفها للعميل
DB_HOST=localhost
DB_PORT=5432
DB_NAME=MaghzAccount
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_IMMEDIATELY

# العملة الافتراضية
VITE_DEFAULT_CURRENCY=YER
VITE_DEFAULT_LANGUAGE=ar
VITE_DEFAULT_THEME=light

# وضع التطبيق: electron | web
VITE_APP_MODE=electron
